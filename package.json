{
  "name": "interviewiq-monorepo",
  "version": "1.0.0",
  "description": "AI-Powered Mock Interview Platform",
  "scripts": {
    "install:all": "cd frontend && npm install",
    "build": "cd frontend && npm run build",
    "start": "concurrently --kill-others \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "start:frontend": "cd frontend && npm run start -- -p ${PORT:-3000}",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
