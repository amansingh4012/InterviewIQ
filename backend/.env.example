# =====================================================
# InterviewIQ Backend Configuration
# =====================================================

# Environment (development/production)
# Set to "production" for production deployments
ENVIRONMENT=development

# =====================================================
# AI/LLM Configuration
# =====================================================
GROQ_API_KEY=gsk_your_groq_api_key_here

# =====================================================
# Database Configuration
# =====================================================
MONGODB_URL=mongodb+srv://username:password@cluster0.mongodb.net/
MONGODB_DB_NAME=interviewIQ

# =====================================================
# Authentication (Clerk)
# =====================================================
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk JWT Public Key (RSA PEM format)
# Can be provided as:
# - Raw PEM string (starts with -----BEGIN PUBLIC KEY-----)
# - Base64-encoded PEM string (for safer env handling)
CLERK_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# =====================================================
# Voice Synthesis
# =====================================================
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# Fallback TTS API Key (optional)
SARVAM_API_KEY=

# =====================================================
# Frontend Configuration
# =====================================================
# IMPORTANT: Must be HTTPS in production
FRONTEND_URL=http://localhost:3000

# =====================================================
# Payment Webhooks (REQUIRED for production)
# =====================================================
# These secrets are used to verify webhook signatures
# Get them from your Stripe/Razorpay dashboard

# Stripe webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=

# Razorpay webhook secret
RAZORPAY_WEBHOOK_SECRET=

# =====================================================
# SECURITY NOTES
# =====================================================
# 1. Never commit this file with real credentials
# 2. In production, use environment variables directly
# 3. Webhook secrets are REQUIRED in production
# 4. FRONTEND_URL must use HTTPS in production
# 5. All API keys should be rotated periodically
